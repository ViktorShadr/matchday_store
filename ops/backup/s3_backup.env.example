# Copy this file to /etc/matchday_store/backup_s3.env or ops/backup/s3_backup.env.
# Keep the real file outside git and restrict permissions: chmod 600 backup_s3.env.

# Object Storage
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_REGION=ru-1

# S3 access keys. Never commit real values.
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key

# Docker Compose
COMPOSE_FILE=/opt/matchday_store/docker-compose.prod.yml
COMPOSE_PROJECT_NAME=matchday_store

# PostgreSQL service/container and credentials.
# These values must match the production .env used by docker-compose.prod.yml.
POSTGRES_SERVICE=
DB_NAME=
DB_USER=
DB_PASSWORD=replace-with-database-password

# Media backup source.
# For the current compose setup media_data is mounted inside web as /app/media.
MEDIA_SOURCE=container
MEDIA_SERVICE=web
MEDIA_PATH=/app/media

# Object names and retention policy
APP_NAME=matchday_store
RETENTION_DAILY_DAYS=14
RETENTION_WEEKLY_WEEKS=8
RETENTION_MONTHLY_MONTHS=6
