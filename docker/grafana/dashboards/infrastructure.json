{
  "title": "Matchday Store — Infrastructure",
  "uid": "matchday-infra",
  "schemaVersion": 36,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL — активные соединения",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{ state }}"
        }
      ]
    },
    {
      "id": 2,
      "title": "PostgreSQL — cache hit ratio",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.90 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m])))",
          "legendFormat": "cache hit"
        }
      ]
    },
    {
      "id": 3,
      "title": "PostgreSQL — транзакции/сек",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(pg_stat_database_xact_commit[1m]))",
          "legendFormat": "commits/sec"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(pg_stat_database_xact_rollback[1m]))",
          "legendFormat": "rollbacks/sec"
        }
      ]
    },
    {
      "id": 4,
      "title": "PostgreSQL — дедлоки",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(pg_stat_database_deadlocks[1h]))",
          "legendFormat": "deadlocks (1h)"
        }
      ]
    },
    {
      "id": 5,
      "title": "PostgreSQL — размер БД",
      "type": "stat",
      "gridPos": { "x": 20, "y": 3, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "pg_database_size_bytes{datname=\"matchday_store\"}",
          "legendFormat": "DB size"
        }
      ]
    },
    {
      "id": 6,
      "title": "PostgreSQL — блокировки",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 7, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (mode) (pg_locks_count)",
          "legendFormat": "{{ mode }}"
        }
      ]
    },
    {
      "id": 7,
      "title": "PostgreSQL — наиболее активные таблицы (seq scans)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 7, "w": 16, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "topk(5, rate(pg_stat_user_tables_seq_scan[5m]))",
          "legendFormat": "{{ relname }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Redis — использование памяти",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        },
        {
          "datasource": "Prometheus",
          "expr": "redis_memory_used_peak_bytes",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "id": 9,
      "title": "Redis — keyspace hit rate",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 14, "w": 4, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.80 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 10,
      "title": "Redis — клиенты",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "redis_connected_clients",
          "legendFormat": "connected"
        },
        {
          "datasource": "Prometheus",
          "expr": "redis_blocked_clients",
          "legendFormat": "blocked"
        }
      ]
    },
    {
      "id": 11,
      "title": "Redis — evictions и expired keys/sec",
      "type": "timeseries",
      "gridPos": { "x": 20, "y": 14, "w": 4, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(redis_evicted_keys_total[1m])",
          "legendFormat": "evictions/sec"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(redis_expired_keys_total[1m])",
          "legendFormat": "expired/sec"
        }
      ]
    },
    {
      "id": 12,
      "title": "Celery — воркеры",
      "type": "stat",
      "gridPos": { "x": 0, "y": 21, "w": 4, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "celery_active_worker_count",
          "legendFormat": "active workers"
        }
      ]
    },
    {
      "id": 13,
      "title": "Celery — глубина очередей",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 21, "w": 10, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "celery_queue_length",
          "legendFormat": "{{ queue_name }}"
        }
      ]
    },
    {
      "id": 14,
      "title": "Celery — задачи (успех / ошибка / retry)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 21, "w": 10, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(celery_task_succeeded_total[1m])) * 60",
          "legendFormat": "succeeded/min"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(celery_task_failed_total[1m])) * 60",
          "legendFormat": "failed/min"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(celery_task_retried_total[1m])) * 60",
          "legendFormat": "retried/min"
        }
      ]
    },
    {
      "id": 15,
      "title": "Celery — время выполнения задач p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 16, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le, name) (rate(celery_task_runtime_bucket[5m])))",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 16,
      "title": "Celery — упавшие задачи (нарастающий итог)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 28, "w": 8, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(celery_task_failed_total[1h]))",
          "legendFormat": "failed (1h)"
        }
      ]
    }
  ]
}
