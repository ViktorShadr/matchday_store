# Email настройки для Gmail
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your@gmail.com

# Другие настройки
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SITE_URL=http://localhost:8000

# Настройки базы данных
DB_NAME=matchday_store
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=db
DB_PORT=5432

# Celery/Redis (необязательно для MVP, письма умеют уходить sync fallback)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Самовывоз
STORE_PICKUP_LOCATION_CODE=main-store
STORE_PICKUP_LOCATION_NAME=Фирменный магазин ФК «Шинник»
STORE_PICKUP_ADDRESS=г. Ярославль, ул. Победы, 12
STORE_PICKUP_HOURS=Ежедневно с 10:00 до 20:00
STORE_PICKUP_PHONE=+7 (4852) 00-00-00
