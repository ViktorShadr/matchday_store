# Email настройки для Gmail
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=your@gmail.com
STAFF_ORDER_NOTIFICATION_EMAILS=staff1@example.com,staff2@example.com
STORE_SUPPORT_EMAIL=shop@shinnik.example
SUPPORT_NOTIFICATION_EMAILS=support1@example.com,support2@example.com

# Другие настройки
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SITE_URL=http://localhost:8000
EMAIL_CONFIRMATION_TOKEN_TTL_HOURS=24
GUEST_ORDER_TOKEN_TTL_DAYS=30

# Rate limiting (Sprint 2)
RATELIMIT_ENABLE=True
RATELIMIT_IP_META_KEY=
RATELIMIT_LOGIN_IP_RATE=20/10m
RATELIMIT_LOGIN_CREDENTIAL_RATE=10/10m
RATELIMIT_REGISTRATION_IP_RATE=12/1h
RATELIMIT_REGISTRATION_EMAIL_RATE=5/1h
RATELIMIT_CONFIRM_RESEND_IP_RATE=8/1h
RATELIMIT_CONFIRM_RESEND_USER_RATE=5/1h
RATELIMIT_CHECKOUT_IP_RATE=12/10m
RATELIMIT_CHECKOUT_USER_RATE=5/10m
RATELIMIT_SUPPORT_POST_RATE=5/10m
CHECKOUT_MAX_ACTIVE_ORDERS=3
CHECKOUT_MAX_QTY_PER_SKU=5
STOCK_RESERVE_MODE_ENABLED=True
ORDER_PICKUP_RETENTION_BUSINESS_DAYS=3
ORDER_AUTO_CANCEL_BATCH_SIZE=100
ORDER_AUTO_CANCEL_INTERVAL_SECONDS=900

# CSP / security headers
# В production рекомендуется enforce-режим, для локальной диагностики можно ставить False
CSP_ENFORCE=True
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Cookie security / reverse proxy
# Для production с HTTPS поставьте True, для временного HTTP по IP оставьте False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_PROTO=False
USE_X_FORWARDED_HOST=False

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0

# Yandex Metrica
# Локально счетчик не загружается: DEBUG=True всегда отключает Метрику.
# В production укажите реальный ID счетчика и METRIKA_ENABLED=True.
METRIKA_ENABLED=False
METRIKA_COUNTER_ID=
# Future consent mode: при True счетчик ждет cookie_consent=accepted.
METRIKA_REQUIRE_CONSENT=False

# Настройки базы данных
DB_NAME=matchday_store
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=db
DB_PORT=5432

# Celery/Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CACHE_URL=redis://redis:6379/1
# Генерация thumbnail при загрузке изображений товара: sync | async
PRODUCT_IMAGE_THUMBNAIL_GENERATION_MODE=sync

# Логирование
LOG_LEVEL=INFO
LOG_JSON=False
GUNICORN_LOG_LEVEL=info

# Самовывоз
STORE_BRAND_NAME=ФК «Шинник»
STORE_PICKUP_LOCATION_CODE=main-store
STORE_PICKUP_LOCATION_NAME=Фирменный магазин ФК «Шинник»
STORE_PICKUP_ADDRESS=г. Ярославль, пл. Труда, 3
STORE_PICKUP_HOURS="пн-пт с 10:00 до 16:00\nсб-вс выходной"
STORE_PICKUP_PHONE=+7 (4852) 00-00-00
